<UserControl x:Class="DustReplay.App.Controls.TitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="36" Background="{StaticResource BgBrush}"
             MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
            <Image x:Name="LogoImg" Width="22" Height="22" Margin="0,0,8,0"/>
            <TextBlock Text="DustReplay" Foreground="{StaticResource TextBrush}"
                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>
        <Border Grid.Column="1" Background="Transparent" Cursor="SizeAll"
                MouseLeftButtonDown="DragArea_MouseLeftButtonDown"/>
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
            <Button Content="&#xE921;" Style="{StaticResource PanelIconBtn}" Click="Minimize_Click"
                    FontFamily="Segoe MDL2 Assets" ToolTip="Küçült"/>
            <Button Content="&#xE922;" Style="{StaticResource PanelIconBtn}" Click="Maximize_Click"
                    FontFamily="Segoe MDL2 Assets" ToolTip="Büyüt"/>
            <Button Content="&#xE8BB;" Style="{StaticResource PanelIconBtn}" Click="Close_Click"
                    FontFamily="Segoe MDL2 Assets" Foreground="#E05555" ToolTip="Kapat"/>
        </StackPanel>
    </Grid>
</UserControl>
