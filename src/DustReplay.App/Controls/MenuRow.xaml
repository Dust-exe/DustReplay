<UserControl x:Class="DustReplay.App.Controls.MenuRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="56">
    <Button x:Name="RowBtn" Style="{StaticResource PanelMenuRow}" Click="RowBtn_Click">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="IconText" Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       Foreground="{StaticResource TextSoftBrush}" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Foreground="{StaticResource TextBrush}"
                           FontSize="13" FontWeight="SemiBold"/>
                <TextBlock x:Name="SubText" Foreground="{StaticResource TextDimBrush}"
                           FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
            <TextBlock x:Name="RightText" Grid.Column="2" FontFamily="Segoe MDL2 Assets"
                       Text="&#xE76C;" Foreground="{StaticResource TextDimBrush}"
                       VerticalAlignment="Center" Margin="8,0,4,0"/>
        </Grid>
    </Button>
</UserControl>
