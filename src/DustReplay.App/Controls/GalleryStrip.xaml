<UserControl x:Class="DustReplay.App.Controls.GalleryStrip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DustReplay.App.Controls">
    <StackPanel>
        <Grid Margin="12,8,12,4">
            <TextBlock Text="Galeri" Foreground="{StaticResource TextBrush}"
                       FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button x:Name="AllBtn" Content="Tümü ›" HorizontalAlignment="Right"
                    Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextDimBrush}"
                    FontSize="11" Padding="4,2" Cursor="Hand" Click="AllBtn_Click"/>
        </Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                      Height="88" Margin="8,0,8,8">
            <StackPanel x:Name="ThumbHost" Orientation="Horizontal"/>
        </ScrollViewer>
        <TextBlock x:Name="EmptyText" Text="Henüz kayıt yok" Visibility="Collapsed"
                   Foreground="{StaticResource TextDimBrush}" FontSize="11"
                   Margin="12,0,12,8" HorizontalAlignment="Center"/>
    </StackPanel>
</UserControl>
