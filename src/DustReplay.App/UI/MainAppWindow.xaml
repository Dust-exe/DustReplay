<Window x:Class="DustReplay.App.UI.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DustReplay.App.Controls"
        Title="DustReplay" Height="680" Width="1000" MinHeight="520" MinWidth="820"
        WindowStyle="None" ResizeMode="CanResize" Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Title bar spans full window width (WhatsApp-style, not only content column) -->
        <controls:TitleBar x:Name="AppTitleBar" Grid.Row="0" Grid.ColumnSpan="2"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="#211C30" BorderThickness="0,0,1,0">
                <DockPanel Margin="12,8,12,12">
                    <StackPanel DockPanel.Dock="Bottom">
                        <Separator Margin="0,8,0,8" Background="#211C30"/>
                        <Button Content="Kaydet (F9)" Style="{StaticResource PrimaryButton}" Margin="0,0,0,6" Click="Save_Click"/>
                        <Button Content="Duraklat" Style="{StaticResource GhostButton}" Click="Toggle_Click"/>
                    </StackPanel>
                    <StackPanel>
                        <Button x:Name="NavGallery" Content="Galeri" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="gallery"/>
                        <Button x:Name="NavRecordings" Content="Kayıtlar" Style="{StaticResource NavButton}" Margin="0,6" Click="Nav_Click" Tag="recordings"/>
                        <Button x:Name="NavSettings" Content="Ayarlar" Style="{StaticResource NavButton}" Margin="0,6" Click="Nav_Click" Tag="settings"/>
                    </StackPanel>
                </DockPanel>
            </Border>
            <Grid Grid.Column="1">
                <Grid x:Name="PageGallery" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="24,16,24,8">
                        <TextBlock Text="Galeri" Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="Bold"/>
                        <Button Content="Yenile" DockPanel.Dock="Right" Width="72" Height="32"
                                Style="{StaticResource GhostButton}" Click="RefreshGallery_Click"/>
                        <Button Content="Klasör" DockPanel.Dock="Right" Width="72" Height="32" Margin="0,0,8,0"
                                Style="{StaticResource GhostButton}" Click="OpenFolder_Click"/>
                    </DockPanel>
                    <ScrollViewer Grid.Row="1" Margin="16,0,16,16" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="GalleryItems">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
