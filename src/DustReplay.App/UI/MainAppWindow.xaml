<Window x:Class="DustReplay.App.UI.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DustReplay" Height="680" Width="1000" MinHeight="520" MinWidth="820"
        Background="{StaticResource BgBrush}" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="{StaticResource PanelBrush}">
            <StackPanel Margin="12">
                <TextBlock Text="DustReplay" Foreground="{StaticResource TextBrush}"
                           FontSize="18" FontWeight="Bold" Margin="0,12,0,20"/>
                <Button x:Name="NavGallery" Content="🖼  Galeri" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="gallery"/>
                <Button x:Name="NavSettings" Content="⚙  Ayarlar" Style="{StaticResource NavButton}" Margin="0,6" Click="Nav_Click" Tag="settings"/>
                <Separator Margin="0,16" Background="#211C30"/>
                <Button Content="💾  Kaydet (F9)" Style="{StaticResource PrimaryButton}" Margin="0,8" Click="Save_Click"/>
                <Button Content="⏸  Duraklat" Style="{StaticResource GhostButton}" Margin="0,6" Click="Toggle_Click"/>
            </StackPanel>
        </Border>
        <Grid Grid.Column="1">
            <Grid x:Name="PageGallery" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Margin="24,20,24,8">
                    <TextBlock Text="Galeri" Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="Bold"/>
                    <Button Content="Yenile" DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Click="RefreshGallery_Click"/>
                    <Button Content="Klasör" DockPanel.Dock="Right" Margin="0,0,8,0" Style="{StaticResource GhostButton}" Click="OpenFolder_Click"/>
                </DockPanel>
                <ScrollViewer Grid.Row="1" Margin="16,0,16,16" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="GalleryItems">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
            <ScrollViewer x:Name="PageSettings" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="24">
                <StackPanel MaxWidth="520">
                    <TextBlock Text="Ayarlar" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="FPS" Foreground="{StaticResource TextSoftBrush}"/>
                    <Slider x:Name="FpsSlider" Minimum="10" Maximum="30" Value="20" TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,4,0,12"/>
                    <TextBlock Text="Buffer (dakika)" Foreground="{StaticResource TextSoftBrush}"/>
                    <Slider x:Name="BufferSlider" Minimum="1" Maximum="30" Value="10" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,4,0,12"/>
                    <TextBlock Text="Yakalama (oyun için gdigrab dene)" Foreground="{StaticResource TextSoftBrush}"/>
                    <ComboBox x:Name="CaptureBackendBox" Margin="0,4,0,12">
                        <ComboBoxItem Content="ddagrab (GPU / düşük yük)" Tag="ddagrab"/>
                        <ComboBoxItem Content="gdigrab (bazı tam ekran oyunlar)" Tag="gdigrab"/>
                    </ComboBox>
                    <TextBlock Text="Max yükseklik (0 = native)" Foreground="{StaticResource TextSoftBrush}"/>
                    <ComboBox x:Name="MaxHeightBox" Margin="0,4,0,12">
                        <ComboBoxItem Content="720p" Tag="720"/>
                        <ComboBoxItem Content="1080p" Tag="1080"/>
                        <ComboBoxItem Content="Native" Tag="0"/>
                    </ComboBox>
                    <TextBlock Text="REC nokta köşesi" Foreground="{StaticResource TextSoftBrush}"/>
                    <ComboBox x:Name="OverlayCornerBox" Margin="0,4,0,16">
                        <ComboBoxItem Content="Sağ üst" Tag="tr"/>
                        <ComboBoxItem Content="Sol üst" Tag="tl"/>
                        <ComboBoxItem Content="Sağ alt" Tag="br"/>
                        <ComboBoxItem Content="Sol alt" Tag="bl"/>
                    </ComboBox>
                    <Button Content="Kaydet ve yeniden başlat" Style="{StaticResource PrimaryButton}" Click="SaveSettings_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
