<Window x:Class="DustReplay.App.UI.SidePanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DustReplay.App.Controls"
        Title="DustReplay" Width="320" WindowStyle="None" AllowsTransparency="True"
        Background="#1A1A1A" ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelHeaderBrush}" Padding="10,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Image x:Name="HeaderLogo" Width="28" Height="28" Margin="0,0,8,0"/>
                    <TextBlock Text="DustReplay" Foreground="{StaticResource TextBrush}"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Border x:Name="LiveBadge" Background="#E05555" CornerRadius="6" Padding="6,2"
                            Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="CANLI" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="&#xE713;" Style="{StaticResource PanelIconBtn}"
                            FontFamily="Segoe MDL2 Assets" ToolTip="Ayarlar" Click="Settings_Click"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource PanelIconBtn}"
                            FontFamily="Segoe MDL2 Assets" Foreground="#E05555" Click="Close_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="#141414">
            <controls:GalleryStrip x:Name="GalleryStrip"/>
        </Border>

        <StackPanel Grid.Row="2">
            <controls:MenuRow x:Name="RowSave" Title="Replay klibi kaydet"
                              Subtitle="F9" IconGlyph="&#xE74E;" Click="Save_Click"/>
            <controls:MenuRow x:Name="RowToggle" Title="Yakalamayı duraklat"
                              Subtitle="F10" IconGlyph="&#xE769;" Click="Toggle_Click"/>
            <controls:MenuRow x:Name="RowApp" Title="Uygulamayı aç"
                              Subtitle="Geniş pencere — galeri ve ayarlar"
                              IconGlyph="&#xE8A7;" Click="OpenApp_Click"/>
            <Rectangle Height="1" Fill="{StaticResource PanelSepBrush}" Margin="12,4"/>
        </StackPanel>

        <Border Grid.Row="3" Padding="14,10" Background="#141414">
            <StackPanel>
                <TextBlock x:Name="BufferText" Text="Buffer: —" Foreground="{StaticResource TextSoftBrush}" FontSize="11"/>
                <ProgressBar x:Name="BufferBar" Height="4" Maximum="100" Value="0" Margin="0,6,0,4"
                             Foreground="{StaticResource AccentBrush}" Background="#211C30"/>
                <TextBlock x:Name="StatusText" Foreground="{StaticResource TextDimBrush}" FontSize="10"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Padding="8,6" Background="#0E0E0E">
            <TextBlock x:Name="VersionText" HorizontalAlignment="Center"
                       Foreground="{StaticResource TextDimBrush}" FontSize="9"/>
        </Border>
    </Grid>
</Window>
