<UserControl x:Class="DustReplay.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
        <StackPanel MaxWidth="560">
            <TextBlock Text="Ayarlar" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>

            <TextBlock Text="Ekran" Style="{StaticResource SectionHeaderStyle}"/>
            <ComboBox x:Name="MonitorBox" Margin="0,4,0,8"/>
            <TextBlock Text="Kayıt yönü" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <ComboBox x:Name="FlipBox" Margin="0,4,0,12"/>

            <TextBlock Text="Kayıt" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="Encoder" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <ComboBox x:Name="EncoderBox" Margin="0,4,0,8"/>
            <TextBlock Text="Buffer (dakika)" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <Slider x:Name="BufferSlider" Minimum="5" Maximum="60" IsSnapToTickEnabled="True" TickFrequency="5" Margin="0,4,0,4"/>
            <TextBlock x:Name="BufferVal" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,8"/>
            <TextBlock Text="FPS" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <Slider x:Name="FpsSlider" Minimum="10" Maximum="30" TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,4,0,4"/>
            <TextBlock x:Name="FpsVal" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,8"/>
            <TextBlock Text="Kalite (CRF/QP)" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <Slider x:Name="QualitySlider" Minimum="18" Maximum="40" Margin="0,4,0,4"/>
            <TextBlock x:Name="QualityVal" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,8"/>
            <TextBlock Text="Max yükseklik" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <ComboBox x:Name="MaxHeightBox" Margin="0,4,0,8"/>
            <TextBlock Text="Yakalama" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <ComboBox x:Name="CaptureBackendBox" Margin="0,4,0,12"/>

            <TextBlock Text="Ses" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="Mikrofon" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <ComboBox x:Name="MicBox" Margin="0,4,0,8"/>
            <TextBlock Text="Sistem sesi" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <ComboBox x:Name="SysBox" Margin="0,4,0,12"/>

            <TextBlock Text="Kısayollar" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="Kaydet" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <TextBox x:Name="HotkeySaveBox" Margin="0,4,0,8"/>
            <TextBlock Text="Duraklat" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <TextBox x:Name="HotkeyToggleBox" Margin="0,4,0,8"/>
            <TextBlock Text="Panel" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <TextBox x:Name="HotkeyPanelBox" Margin="0,4,0,8"/>
            <TextBlock Text="Panel tarafı" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <ComboBox x:Name="PanelSideBox" Margin="0,4,0,12"/>

            <TextBlock Text="Çıktı" Style="{StaticResource SectionHeaderStyle}"/>
            <Grid Margin="0,4,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="OutputDirBox" Grid.Column="0" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Gözat" Style="{StaticResource GhostButton}" Click="BrowseOutput_Click"/>
            </Grid>

            <TextBlock Text="Gösterge" Style="{StaticResource SectionHeaderStyle}"/>
            <CheckBox x:Name="OverlayEnabledChk" Content="REC noktası göster" Foreground="{StaticResource TextSoftBrush}" Margin="0,4,0,8"/>
            <TextBlock Text="REC köşesi" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <ComboBox x:Name="OverlayCornerBox" Margin="0,4,0,12"/>

            <TextBlock Text="Donanım" Style="{StaticResource SectionHeaderStyle}"/>
            <CheckBox x:Name="StatsCpuChk" Content="CPU" Foreground="{StaticResource TextSoftBrush}" Margin="0,2,0,2"/>
            <CheckBox x:Name="StatsRamChk" Content="RAM" Foreground="{StaticResource TextSoftBrush}" Margin="0,2,0,2"/>
            <CheckBox x:Name="StatsGpuChk" Content="GPU" Foreground="{StaticResource TextSoftBrush}" Margin="0,2,0,2"/>
            <CheckBox x:Name="StatsFpsChk" Content="FPS" Foreground="{StaticResource TextSoftBrush}" Margin="0,2,0,8"/>
            <TextBlock Text="İstatistik modu" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <ComboBox x:Name="StatsModeBox" Margin="0,4,0,8"/>
            <TextBlock Text="İstatistik köşesi" Foreground="{StaticResource TextSoftBrush}" FontSize="12"/>
            <ComboBox x:Name="StatsCornerBox" Margin="0,4,0,12"/>

            <TextBlock Text="Başlangıç" Style="{StaticResource SectionHeaderStyle}"/>
            <CheckBox x:Name="StartupChk" Content="Windows ile başlat" Foreground="{StaticResource TextSoftBrush}" Margin="0,4,0,12"/>

            <TextBlock Text="Dil" Style="{StaticResource SectionHeaderStyle}"/>
            <ComboBox x:Name="LangBox" Margin="0,4,0,16">
                <ComboBoxItem Content="Türkçe" Tag="tr"/>
                <ComboBoxItem Content="English" Tag="en"/>
            </ComboBox>

            <Button Content="Kaydet ve yeniden başlat" Style="{StaticResource PrimaryButton}"
                    Click="Save_Click" Margin="0,8,0,24"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
